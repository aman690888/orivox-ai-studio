          "id": "o1-t1",
          "type": "Title",
          "data": {
            "content": "**The Foundational Era of Artificial Intelligence**"
          }
        },
        "o1-p1": {
          "id": "o1-p1",
          "type": "Paragraph",
          "data": {
            "content": "Early artificial intelligence relied on symbolic processing and rigid rule-based systems. Scientists crafted explicit logic trees to guide machines through specific tasks, defining clear paths for problem-solving within controlled environments and limited domains."
          }
        },
        "o1-i1": {
          "id": "o1-i1",
